{
  "name": "personal-agent-os",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:web-demo": "node --import tsx scripts/generate-command-center-demo.ts",
    "predev:web": "npm run generate:web-demo",
    "dev:web": "vite",
    "start:agent-daemon": "node --import tsx scripts/run-agent-daemon.ts",
    "start:slack-bridge": "node --import tsx scripts/run-slack-bridge.ts",
    "start:telegram-bridge": "node --import tsx scripts/run-telegram-bridge.ts",
    "service:install": "node --import tsx scripts/manage-launch-agents.ts install",
    "service:uninstall": "node --import tsx scripts/manage-launch-agents.ts uninstall",
    "service:status": "node --import tsx scripts/manage-launch-agents.ts status",
    "build": "tsc -p tsconfig.json",
    "prebuild:web": "npm run generate:web-demo",
    "build:web": "vite build",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx packages/core/test/*.test.ts",
    "test:ui": "node --test --test-concurrency=1 --import tsx tests/ui/*.test.ts",
    "test:daemon": "node --test --import tsx tests/*.test.ts",
    "test:mvp": "npm test && npm run test:ui"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "playwright": "^1.59.1",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vite": "^8.0.9"
  }
}
